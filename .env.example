NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173 

# Public backend URL for Meta webhook (production). Leave empty locally — derived from request.
# PUBLIC_API_URL=https://your-api.onrender.com

MONGO_URI=mongodb://127.0.0.1:27017/internal_crm
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Upstash / managed Redis (preferred for production)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# Local Redis fallback (only if REDIS_URL is unset)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# BullMQ workers are disabled by default to avoid Redis command-script issues.
# Set to true only after queue/redis compatibility is verified.
# ENABLE_WORKERS=true

WORK_START_HOUR=10
WORK_END_HOUR=19
DEFAULT_TIMEZONE=Asia/Kolkata
TASK_OVERDUE_GRACE_MINUTES=15

# Meta Lead Ads webhook
META_VERIFY_TOKEN=choose_a_long_random_string
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
